<Window x:Class="Macronic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="1000" Height="650"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        Opacity="0"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border x:Name="OuterBorder" CornerRadius="12" Background="#0a0a0a"
            BorderBrush="#222222" BorderThickness="1"
            ClipToBounds="True">

        <Grid ClipToBounds="True">

            <!-- STARTUP OVERLAY -->
            <Grid x:Name="StartupGrid" Background="#0a0a0a" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="AsciiText"
                               Text="MACRONIC"
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="96"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center"
                               Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                    <Rectangle x:Name="AccentLine"
                               Height="2" Width="0"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Fill="{StaticResource Accent}"
                               Opacity="0.8"/>
                    <TextBlock x:Name="StatusText"
                               FontFamily="{StaticResource IBMPlexMono}"
                               FontSize="11"
                               Foreground="{StaticResource Muted}"
                               HorizontalAlignment="Center"
                               Margin="0,22,0,0"
                               Opacity="0"
                               Text=""/>
                </StackPanel>
            </Grid>

            <!-- GOODBYE OVERLAY -->
            <Grid x:Name="GoodbyeOverlay" Background="#0a0a0a" Panel.ZIndex="11" Visibility="Collapsed" Opacity="0">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="GOODBYE" FontFamily="{StaticResource BebasNeue}" FontSize="96" Foreground="#f5f5f5" HorizontalAlignment="Center"/>
                    <TextBlock Text="See you next time!" FontFamily="{StaticResource IBMPlexMono}" FontSize="11" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Grid>

            <!-- MAIN UI -->
            <Border x:Name="MainGrid" Visibility="Collapsed"
                    Background="Transparent" Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50"/> <!-- TITLE BAR & NAV -->
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="50"/> <!-- FOOTER -->
                    </Grid.RowDefinitions>

                    <!-- HEADER / NAVIGATION -->
                    <Border Grid.Row="0"
                            Background="#0a0a0a"
                            BorderBrush="#222222"
                            BorderThickness="0,0,0,1"
                            MouseLeftButtonDown="TitleBar_MouseDown"
                            MouseMove="TitleBar_MouseMove">
                        <Grid Margin="20,0,10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M 0,0 L 20,0 L 30,15 L 10,15 Z" Fill="{StaticResource Accent}" Width="30" Height="15" Margin="0,0,10,0" Stretch="Uniform"/>
                                <TextBlock Text="ALL SERVICES"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#f5f5f5"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- TOP NAVIGATION -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="40,0,0,0">
                                <Button x:Name="BtnMacros" Content="DASHBOARD" Style="{StaticResource TopNavBtn}" Tag="Active" Click="BtnMacros_Click" Margin="0,0,20,0"/>
                                <Button x:Name="BtnKeybinds" Content="KEYBINDS" Style="{StaticResource TopNavBtn}" Click="BtnKeybinds_Click" Margin="0,0,20,0"/>
                                <Button x:Name="BtnSettings" Content="SETTINGS" Style="{StaticResource TopNavBtn}" Click="BtnSettings_Click" Margin="0,0,20,0"/>
                                <Button x:Name="BtnCrosshairs" Content="CROSSHAIRS" Style="{StaticResource TopNavBtn}" Click="BtnCrosshairs_Click" Margin="0,0,20,0"/>
                                <Button x:Name="BtnArraylist" Content="ARRAYLIST" Style="{StaticResource TopNavBtn}" Click="BtnArraylist_Click" Margin="0,0,20,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="#1a2a1a" CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="#44ff44" Margin="0,0,6,0"/>
                                        <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold" Foreground="#44ff44" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <Button Content="—" Style="{StaticResource TitleIconBtn}" Click="Minimize_Click"/>
                                <Button Style="{StaticResource TitleCloseBtn}" Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CONTENT AREA -->
                    <Grid Grid.Row="1" Background="#0d0d0d">
                        <ScrollViewer x:Name="MainScrollViewer" VerticalScrollBarVisibility="Auto" Padding="40,30">
                            <Grid>
                                <!-- DASHBOARD / HELPERS PANEL -->
                                <StackPanel x:Name="MacrosPanel" Visibility="Visible">
                                    <TextBlock Text="Panel Control" FontFamily="{StaticResource IBMPlexMono}" FontSize="14" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                    
                                    <!-- MODULE SELECTOR (HORIZONTAL) -->
                                    <UniformGrid Columns="5" Margin="0,0,0,30">
                                        <ToggleButton x:Name="DeToggle" Content="Drag Edit" Style="{StaticResource ModuleBtn}" Margin="0,0,10,0" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        <Ellipse x:Name="DeStatusDot" Width="8" Height="8" Fill="#1a2a1a" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <ToggleButton x:Name="SeToggle" Content="Single Edit" Style="{StaticResource ModuleBtn}" Margin="0,0,10,0" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        <Ellipse x:Name="SeStatusDot" Width="8" Height="8" Fill="#1a2a1a" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <ToggleButton x:Name="DbToggle" Content="Double Edit" Style="{StaticResource ModuleBtn}" Margin="0,0,10,0" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        <Ellipse x:Name="DbStatusDot" Width="8" Height="8" Fill="#1a2a1a" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <ToggleButton x:Name="IbToggle" Content="Instant Build" Style="{StaticResource ModuleBtn}" Margin="0,0,10,0" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        <Ellipse x:Name="IbStatusDot" Width="8" Height="8" Fill="#1a2a1a" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                        <ToggleButton x:Name="SpToggle" Content="Sprint" Style="{StaticResource ModuleBtn}" Margin="0,0,10,0" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        <Ellipse x:Name="SpStatusDot" Width="8" Height="8" Fill="#1a2a1a" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,10,0"/>
                                    </UniformGrid>

                                    <!-- DYNAMIC SETTINGS AREA (Currently showing Double Edit as example) -->
                                    <Grid x:Name="ModuleSettingsContainer">
                                        <!-- This would be dynamically updated, but for now we put everything in a stack -->
                                        <StackPanel>
                                            <!-- DRAG EDIT SECTION -->
                                            <Border x:Name="DePanel" Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Drag Edit" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <ToggleButton x:Name="DeToggleSwitch" IsChecked="{Binding IsChecked, ElementName=DeToggle, Mode=TwoWay}" Style="{StaticResource ToggleSwitch}"/>
                                                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="DeBindBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="DeBindBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,10">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                            <TextBlock Text="ms" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="DELAY" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock x:Name="DeDelayText" Text="0 ms" FontSize="11" Foreground="#f5f5f5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Slider x:Name="DeDelaySlider" Style="{StaticResource DarkSlider}" Minimum="0" Maximum="100" ValueChanged="Sliders_Changed"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- SINGLE EDIT SECTION -->
                                            <Border x:Name="SePanel" Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Single Edit" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <ToggleButton x:Name="SeToggleSwitch" IsChecked="{Binding IsChecked, ElementName=SeToggle, Mode=TwoWay}" Style="{StaticResource ToggleSwitch}"/>
                                                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="SeBindBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="SeBindBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,10">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                            <TextBlock Text="ms" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="DELAY" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock x:Name="SeDelayText" Text="0 ms" FontSize="11" Foreground="#f5f5f5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Slider x:Name="SeDelaySlider" Style="{StaticResource DarkSlider}" Minimum="0" Maximum="100" ValueChanged="Sliders_Changed"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- INSTANT BUILD SECTION -->
                                            <Border x:Name="IbPanel" Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Instant Build" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <ToggleButton x:Name="IbToggleSwitch" IsChecked="{Binding IsChecked, ElementName=IbToggle, Mode=TwoWay}" Style="{StaticResource ToggleSwitch}"/>
                                                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="IbBindBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="IbBindBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,10">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                            <TextBlock Text="ms" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="DELAY" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock x:Name="IbDelayText" Text="0 ms" FontSize="11" Foreground="#f5f5f5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Slider x:Name="IbDelaySlider" Style="{StaticResource DarkSlider}" Minimum="0" Maximum="100" ValueChanged="Sliders_Changed"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>



                                            <!-- SPRINT MODE DROPDOWN -->
                                            <Border Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Sprint Mode" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <Button x:Name="SpModeBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="SpModeBtn_Click" Content="Toggle"/>
                                                    </StackPanel>

                                                    <Grid x:Name="SpModeDropdown" Grid.Row="2" Grid.ColumnSpan="2" Height="0" VerticalAlignment="Top" Margin="0,10,0,0">
                                                        <StackPanel>
                                                            <Button x:Name="SpModeToggleBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="SpModeToggleBtn_Click" Content="Toggle"/>
                                                            <Button x:Name="SpModeHoldBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="SpModeHoldBtn_Click" Content="Hold"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>


                                            <Border Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Sprint" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <ToggleButton x:Name="SpToggleSwitch" IsChecked="{Binding IsChecked, ElementName=SpToggle, Mode=TwoWay}" Style="{StaticResource ToggleSwitch}"/>
                                                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="SpBindBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="SpBindBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,10">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                            <TextBlock Text="ms" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="DELAY" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock x:Name="SpDelayText" Text="0 ms" FontSize="11" Foreground="#f5f5f5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Slider x:Name="SpDelaySlider" Style="{StaticResource DarkSlider}" Minimum="0" Maximum="100" ValueChanged="Sliders_Changed"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- DOUBLE EDIT SECTION -->
                                            <Border x:Name="DbPanel" Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Double Edit" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                        <ToggleButton x:Name="DbToggleSwitch" IsChecked="{Binding IsChecked, ElementName=DbToggle, Mode=TwoWay}" Style="{StaticResource ToggleSwitch}"/>
                                                        <TextBlock Text="ON" FontSize="10" Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="DbBindBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="DbBindBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <Grid Margin="0,0,0,10">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                            <TextBlock Text="ms" Foreground="{StaticResource Accent}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <TextBlock Text="DELAY" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                    <TextBlock x:Name="DbDelayText" Text="0 ms" FontSize="11" Foreground="#f5f5f5" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </Grid>
                                                                <Slider x:Name="DbDelaySlider" Style="{StaticResource DarkSlider}" Minimum="0" Maximum="100" ValueChanged="Sliders_Changed"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            
                                            <!-- ITEM PULLOUT SECTION -->
                                            <Border x:Name="PulloutPanel" Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Item Pullout Configuration" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                                    <UniformGrid Columns="4">
                                                        <CheckBox x:Name="PulloutPickaxeBox" Content="Pickaxe" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutShotgunBox" Content="Shotgun" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutSlot1Box" Content="Slot 1" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutSlot2Box" Content="Slot 2" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutSlot3Box" Content="Slot 3" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutSlot4Box" Content="Slot 4" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                        <CheckBox x:Name="PulloutSlot5Box" Content="Slot 5" Foreground="#f5f5f5" Checked="Toggles_Changed" Unchecked="Toggles_Changed" Margin="0,0,0,10"/>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>

                                <!-- SETTINGS PANEL -->
                                <StackPanel x:Name="SettingsPanel" Visibility="Collapsed" Margin="0,0,0,0">
                                    <TextBlock Text="Application Settings" FontFamily="{StaticResource IBMPlexMono}" FontSize="14" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                    <Border Background="#111111" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                                        <StackPanel>
                                            <CheckBox x:Name="AutoUpdateBox" Content="Enable Auto Updates" Foreground="#f5f5f5" Margin="0,0,0,15" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                            <CheckBox x:Name="OverlayBox" Content="Show In-Game Overlay" Foreground="#f5f5f5" Margin="0,0,0,15" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                            <CheckBox x:Name="BeepBox" Content="Sound Feedback on Toggle" Foreground="#f5f5f5" Margin="0,0,0,15" Checked="Toggles_Changed" Unchecked="Toggles_Changed"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- KEYBINDS PANEL -->
                                <StackPanel x:Name="KeybindsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Game Keybinds" FontFamily="{StaticResource IBMPlexMono}" FontSize="14" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                    <Border Background="#111111" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                                        <UniformGrid Columns="2">
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Edit Key" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbBuildingEditBtn" Style="{StaticResource DarkBtn}" Click="KbBuildingEditBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Select Edit" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSelectBuildingEditBtn" Style="{StaticResource DarkBtn}" Click="KbSelectBuildingEditBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Pickaxe" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbPickaxeBtn" Style="{StaticResource DarkBtn}" Click="KbPickaxeBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Shotgun" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbShotgunBtn" Style="{StaticResource DarkBtn}" Click="KbShotgunBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Slot 1" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSlot1Btn" Style="{StaticResource DarkBtn}" Click="KbSlot1Btn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Slot 2" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSlot2Btn" Style="{StaticResource DarkBtn}" Click="KbSlot2Btn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Slot 3" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSlot3Btn" Style="{StaticResource DarkBtn}" Click="KbSlot3Btn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Slot 4" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSlot4Btn" Style="{StaticResource DarkBtn}" Click="KbSlot4Btn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Slot 5" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSlot5Btn" Style="{StaticResource DarkBtn}" Click="KbSlot5Btn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Wall" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbWallBtn" Style="{StaticResource DarkBtn}" Click="KbWallBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Floor" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbFloorBtn" Style="{StaticResource DarkBtn}" Click="KbFloorBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Stairs" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbStairsBtn" Style="{StaticResource DarkBtn}" Click="KbStairsBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Cone" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbConeBtn" Style="{StaticResource DarkBtn}" Click="KbConeBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Sec. Place" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSecondaryPlaceBuildingBtn" Style="{StaticResource DarkBtn}" Click="KbSecondaryPlaceBuildingBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Sprint" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSprintBtn" Style="{StaticResource DarkBtn}" Click="KbSprintBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Walk Fwd" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbWalkForwardBtn" Style="{StaticResource DarkBtn}" Click="KbWalkForwardBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Interact" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbInteractBtn" Style="{StaticResource DarkBtn}" Click="KbInteractBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="10,0,0,10">
                                                <TextBlock Text="Sec. Shoot" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSecondaryShootBtn" Style="{StaticResource DarkBtn}" Click="KbSecondaryShootBtn_Click"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,10,10">
                                                <TextBlock Text="Sec. Wall" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                                <Button x:Name="KbSecondaryWallBtn" Style="{StaticResource DarkBtn}" Click="KbSecondaryWallBtn_Click"/>
                                            </StackPanel>
                                        </UniformGrid>
                                    </Border>
                                </StackPanel>

                                <!-- CROSSHAIRS PANEL -->
                                <StackPanel x:Name="CrosshairsPanel" Visibility="Collapsed">
                                    <TextBlock Text="Crosshair Settings" FontFamily="{StaticResource IBMPlexMono}" FontSize="14" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                    <Border Background="#111111" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Templates" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,10"/>
                                            <StackPanel x:Name="CrTemplatePanel" Orientation="Horizontal" Margin="0,0,0,20"/>
                                            <TextBlock Text="Colors" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,10"/>
                                            <StackPanel x:Name="CrColorPanel" Orientation="Horizontal" Margin="0,0,0,20"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                                <TextBlock Text="Outline" FontSize="12" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                <ToggleButton x:Name="CrOutlineToggle" Style="{StaticResource ToggleSwitch}" Checked="CrToggle_Changed" Unchecked="CrToggle_Changed"/>
                                            </StackPanel>
                                            <TextBlock Text="Outline Size" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,5"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="CrOutlineSizeSlider" Style="{StaticResource DarkSlider}" Width="200" Minimum="1" Maximum="10" ValueChanged="CrOutlineSizeSlider_Changed"/>
                                                <TextBlock x:Name="CrOutlineSizeLabel" Text="1" Foreground="#f5f5f5" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="Crosshair Size" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,15,0,5"/>
                                            <StackPanel Orientation="Horizontal">
                                                <Slider x:Name="CrSizeSlider" Style="{StaticResource DarkSlider}" Width="200" Minimum="10" Maximum="200" ValueChanged="CrSizeSlider_Changed"/>
                                                <TextBlock x:Name="CrSizeLabel" Text="100%" Foreground="#f5f5f5" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                            <!-- PROOF KEY SETTING -->
                                            <Border Background="#111111" CornerRadius="8" Padding="25" Margin="0,0,0,20" BorderBrush="#222222" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="20"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                        <TextBlock Text="Proof Key" FontSize="14" FontWeight="Bold" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                        <Border Background="#1a1a1a" CornerRadius="6" Padding="15,10">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                                    <Border Background="{StaticResource AccentDim}" CornerRadius="4" Width="24" Height="24" Margin="0,0,10,0">
                                                                        <TextBlock Text="K" Foreground="{StaticResource Accent}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <TextBlock Text="KEYBIND" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                                <Button x:Name="ProofKeyBtn" Style="{StaticResource DarkBtn}" Background="Transparent" HorizontalContentAlignment="Left" Click="ProofKeyBtn_Click" Content="R"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- ARRAYLIST PANEL -->
                                <StackPanel x:Name="ArraylistPanel" Visibility="Collapsed">
                                    <TextBlock Text="ArrayList Settings" FontFamily="{StaticResource IBMPlexMono}" FontSize="14" Foreground="#f5f5f5" Margin="0,0,0,20"/>
                                    <Border Background="#111111" CornerRadius="8" Padding="25" BorderBrush="#222222" BorderThickness="1">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                                                <TextBlock Text="Enabled" FontSize="12" Foreground="#f5f5f5" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                                <ToggleButton x:Name="AlEnabledToggle" Style="{StaticResource ToggleSwitch}" Checked="AlToggle_Changed" Unchecked="AlToggle_Changed"/>
                                            </StackPanel>
                                            <TextBlock Text="Position" FontSize="10" Foreground="{StaticResource Muted}" Margin="0,0,0,10"/>
                                            <UniformGrid Columns="2">
                                                <Button x:Name="AlPosTopLeft" Content="Top Left" Style="{StaticResource DarkBtn}" Click="AlPosTopLeft_Click" Margin="0,0,5,5"/>
                                                <Button x:Name="AlPosTopRight" Content="Top Right" Style="{StaticResource DarkBtn}" Click="AlPosTopRight_Click" Margin="5,0,0,5"/>
                                                <Button x:Name="AlPosBotLeft" Content="Bottom Left" Style="{StaticResource DarkBtn}" Click="AlPosBotLeft_Click" Margin="0,5,5,0"/>
                                                <Button x:Name="AlPosBotRight" Content="Bottom Right" Style="{StaticResource DarkBtn}" Click="AlPosBotRight_Click" Margin="5,5,0,0"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <!-- FOOTER -->
                    <Border Grid.Row="2" Background="#0a0a0a" BorderBrush="#222222" BorderThickness="0,1,0,0">
                        <Grid Margin="20,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <Button Content="Apply Settings" Style="{StaticResource AccentBtnPink}" Width="120" Margin="0,0,10,0" Click="Export_Click"/>
                                <Button Content="Reset All" Style="{StaticResource DarkBtn}" Background="#1a1a1a" Width="100" Click="Import_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <TextBlock Text="In Game FPS:" FontSize="10" Foreground="{StaticResource Muted}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Background="#1a1a1a" Foreground="#f5f5f5" BorderThickness="0" Width="80" Height="24" VerticalContentAlignment="Center">
                                    <ComboBoxItem Content="144 FPS"/>
                                    <ComboBoxItem Content="240 FPS"/>
                                    <ComboBoxItem Content="360 FPS"/>
                                    <ComboBoxItem Content="500+" IsSelected="True"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
