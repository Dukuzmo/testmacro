<Window x:Class="Macronic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="1000" Height="650"
        WindowStyle="None" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        UseLayoutRounding="True"
        Opacity="0"
        RenderOptions.BitmapScalingMode="HighQuality"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Border x:Name="OuterBorder" CornerRadius="0" Background="#080808"
            BorderBrush="#1e1e1e" BorderThickness="1"
            ClipToBounds="True">

        <Grid ClipToBounds="True">

            <Grid x:Name="StartupGrid" Background="#080808" Panel.ZIndex="10">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <TextBlock x:Name="AsciiText"
                               Text="MACRONIC"
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="96"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center"
                               Opacity="0"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <ScaleTransform/>
                        </TextBlock.RenderTransform>
                    </TextBlock>

                    <Rectangle x:Name="AccentLine"
                               Height="1" Width="0"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               Fill="#f5f5f5"
                               Opacity="0.25"/>

                    <TextBlock x:Name="StatusText"
                               FontFamily="{StaticResource IBMPlexMono}"
                               FontSize="11"
                               Foreground="#5a5a5a"
                               HorizontalAlignment="Center"
                               Margin="0,22,0,0"
                               Opacity="0"
                               Text=""/>

                </StackPanel>
            </Grid>

            <Border x:Name="MainGrid" Visibility="Collapsed"
                    Background="Transparent" Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="#080808"
                            BorderBrush="#1e1e1e"
                            BorderThickness="0,0,0,1"
                            MouseLeftButtonDown="TitleBar_MouseDown"
                            MouseMove="TitleBar_MouseMove">
                        <Grid Margin="18,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="MACRONIC"
                                           FontFamily="{StaticResource BebasNeue}"
                                           FontSize="17"
                                           Foreground="#f5f5f5"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" PREMIUM"
                                           FontFamily="{StaticResource BebasNeue}"
                                           FontSize="17"
                                           Foreground="#5a5a5a"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" — v1.0.0"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="9"
                                           Foreground="#2a2a2a"
                                           VerticalAlignment="Center"
                                           Margin="10,1,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                <Button Content="—"
                                        Style="{StaticResource TitleIconBtn}"
                                        FontFamily="{StaticResource IBMPlexMono}"
                                        FontSize="12"
                                        Click="Minimize_Click"/>
                                <Button Style="{StaticResource TitleCloseBtn}"
                                        Margin="1,0,0,0"
                                        Click="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="165"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="#080808"
                                BorderBrush="#1e1e1e"
                                BorderThickness="0,0,1,0">
                            <StackPanel Margin="0,20,0,0">

                                <TextBlock Text="MAIN"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="9"
                                           Foreground="#5a5a5a"
                                           Margin="16,0,0,6"/>

                                <Button x:Name="BtnMacros"
                                        Content="Helpers"
                                        Style="{StaticResource SideNavBtn}"
                                        Background="{StaticResource BgBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnMacros_Click">
                                    <Button.Tag>
                                        <SolidColorBrush Color="#1e1e1e"/>
                                    </Button.Tag>
                                </Button>

                                <TextBlock Text="SYSTEM"
                                           FontFamily="{StaticResource IBMPlexMono}"
                                           FontSize="9"
                                           Foreground="#5a5a5a"
                                           Margin="16,18,0,6"/>

                                <Button x:Name="BtnSettings"
                                        Content="Settings"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnSettings_Click"/>

                                <Button x:Name="BtnKeybinds"
                                        Content="Keybinds"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnKeybinds_Click"/>

                                <Button x:Name="BtnCrosshairs"
                                        Content="Crosshairs"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnCrosshairs_Click"/>

                                <Button x:Name="BtnArraylist"
                                        Content="Arraylist"
                                        Style="{StaticResource SideNavBtn}"
                                        Margin="0,0,0,2"
                                        Click="BtnArraylist_Click"/>

                                <Rectangle Height="1" Margin="16,28,16,0" Fill="#1e1e1e" Opacity="1"/>

                            </StackPanel>
                        </Border>

                        <ScrollViewer x:Name="MainScrollViewer"
                                      Grid.Column="1"
                                      Background="#080808"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="0,0,2,0">
                            <Grid>

                                <StackPanel x:Name="MacrosPanel" Margin="28,24,28,28">

                                    <TextBlock Text="HELPERS"
                                               FontFamily="{StaticResource BebasNeue}"
                                               FontSize="38"
                                               Foreground="#f5f5f5"
                                               Margin="0,0,0,2"/>
                                    <TextBlock Text="Configure your macro helpers and automation keybinds"
                                               FontFamily="{StaticResource IBMPlexMono}"
                                               FontSize="10"
                                               Foreground="#5a5a5a"
                                               Margin="0,0,0,18"/>
                                    <Rectangle Height="1" Fill="#1e1e1e" Margin="0,0,0,18"/>

                                    <!-- DRAG EDIT -->
                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Padding="18,14,18,14">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="DE"
                                                                   FontFamily="{StaticResource BebasNeue}"
                                                                   FontSize="34"
                                                                   Foreground="#2a2a2a"
                                                                   VerticalAlignment="Center"
                                                                   Width="46"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="DeStatusDot"
                                                                         Width="5" Height="5"
                                                                         Fill="#1a2a1a"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                                <TextBlock Text="DRAG EDIT"
                                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="#f5f5f5"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Automatically drag edits when holding down the bound key"
                                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                                       FontSize="10"
                                                                       Foreground="#5a5a5a"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="DeToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="Toggles_Changed"
                                                                  Unchecked="Toggles_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="18,14,18,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="KEYBIND"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="9" Foreground="#5a5a5a"/>
                                                    <Button x:Name="DeBindBtn"
                                                            Style="{StaticResource DarkBtn}"
                                                            Margin="0,5,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="DeBindBtn_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,1,0,0"
                                                    Padding="18,12,18,14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="DELAY (MS)"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#5a5a5a"/>
                                                        <TextBlock x:Name="DeDelayLabel"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="DeSlider"
                                                            Style="{StaticResource DarkSlider}"
                                                            Minimum="10" Maximum="200" Value="85"
                                                            ValueChanged="DeSlider_Changed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- SINGLE EDIT -->
                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Padding="18,14,18,14">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="SE"
                                                                   FontFamily="{StaticResource BebasNeue}"
                                                                   FontSize="34"
                                                                   Foreground="#2a2a2a"
                                                                   VerticalAlignment="Center"
                                                                   Width="46"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="SeStatusDot"
                                                                         Width="5" Height="5"
                                                                         Fill="#1a2a1a"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                                <TextBlock Text="SINGLE EDIT"
                                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="#f5f5f5"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Instant edits a build with one click"
                                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                                       FontSize="10"
                                                                       Foreground="#5a5a5a"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="SeToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="Toggles_Changed"
                                                                  Unchecked="Toggles_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="18,14,18,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="KEYBIND"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="9" Foreground="#5a5a5a"/>
                                                    <Button x:Name="SeBindBtn"
                                                            Style="{StaticResource DarkBtn}"
                                                            Margin="0,5,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="SeBindBtn_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,1,0,0"
                                                    Padding="18,12,18,14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="DELAY (MS)"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#5a5a5a"/>
                                                        <TextBlock x:Name="SeDelayLabel"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="SeSlider"
                                                            Style="{StaticResource DarkSlider}"
                                                            Minimum="10" Maximum="200" Value="85"
                                                            ValueChanged="SeSlider_Changed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- DOUBLE EDIT -->
                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Padding="18,14,18,14">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="DB"
                                                                   FontFamily="{StaticResource BebasNeue}"
                                                                   FontSize="34"
                                                                   Foreground="#2a2a2a"
                                                                   VerticalAlignment="Center"
                                                                   Width="46"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="DbStatusDot"
                                                                         Width="5" Height="5"
                                                                         Fill="#1a2a1a"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                                <TextBlock Text="DOUBLE EDIT"
                                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="#f5f5f5"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Edits a build twice while holding down the bound key"
                                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                                       FontSize="10"
                                                                       Foreground="#5a5a5a"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="DbToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="Toggles_Changed"
                                                                  Unchecked="Toggles_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="18,14,18,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="KEYBIND"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="9" Foreground="#5a5a5a"/>
                                                    <Button x:Name="DbBindBtn"
                                                            Style="{StaticResource DarkBtn}"
                                                            Margin="0,5,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="DbBindBtn_Click"/>
                                                </StackPanel>
                                            </Grid>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,1,0,0"
                                                    Padding="18,12,18,14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="DELAY (MS)"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#5a5a5a"/>
                                                        <TextBlock x:Name="DbDelayLabel"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="DbSlider"
                                                            Style="{StaticResource DarkSlider}"
                                                            Minimum="10" Maximum="200" Value="85"
                                                            ValueChanged="DbSlider_Changed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- INSTANT BUILD -->
                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Padding="18,14,18,14">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="IB"
                                                                   FontFamily="{StaticResource BebasNeue}"
                                                                   FontSize="34"
                                                                   Foreground="#2a2a2a"
                                                                   VerticalAlignment="Center"
                                                                   Width="46"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="IbStatusDot"
                                                                         Width="5" Height="5"
                                                                         Fill="#1a2a1a"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                                <TextBlock Text="INSTANT BUILD"
                                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="#f5f5f5"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Instantly places your builds with 1 press"
                                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                                       FontSize="10"
                                                                       Foreground="#5a5a5a"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="IbToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="Toggles_Changed"
                                                                  Unchecked="Toggles_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,1,0,0"
                                                    Padding="18,12,18,14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="DELAY (MS)"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#5a5a5a"/>
                                                        <TextBlock x:Name="IbDelayLabel"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" FontWeight="Bold"
                                                                   Foreground="#f5f5f5"
                                                                   HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="IbSlider"
                                                            Style="{StaticResource DarkSlider}"
                                                            Minimum="10" Maximum="200" Value="85"
                                                            ValueChanged="IbSlider_Changed"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- SPRINT -->
                                    <Border BorderBrush="#1e1e1e" BorderThickness="1"
                                            Background="#0f0f0f" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,0,0,1"
                                                    Padding="18,14,18,14">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="SP"
                                                                   FontFamily="{StaticResource BebasNeue}"
                                                                   FontSize="34"
                                                                   Foreground="#2a2a2a"
                                                                   VerticalAlignment="Center"
                                                                   Width="46"
                                                                   Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Ellipse x:Name="SpStatusDot"
                                                                         Width="5" Height="5"
                                                                         Fill="#1a2a1a"
                                                                         Margin="0,0,8,0"
                                                                         VerticalAlignment="Center"/>
                                                                <TextBlock Text="SPRINT"
                                                                           FontFamily="{StaticResource IBMPlexMono}"
                                                                           FontSize="11"
                                                                           FontWeight="Bold"
                                                                           Foreground="#f5f5f5"/>
                                                            </StackPanel>
                                                            <TextBlock Text="Keeps sprinting once pressed the bind"
                                                                       FontFamily="{StaticResource IBMPlexMono}"
                                                                       FontSize="10"
                                                                       Foreground="#5a5a5a"
                                                                       Margin="0,4,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="SpToggle"
                                                                  Style="{StaticResource ToggleSwitch}"
                                                                  HorizontalAlignment="Right"
                                                                  VerticalAlignment="Center"
                                                                  Checked="Toggles_Changed"
                                                                  Unchecked="Toggles_Changed"/>
                                                </Grid>
                                            </Border>

                                            <Grid Margin="18,14,18,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="KEYBIND"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="9" Foreground="#5a5a5a"/>
                                                    <Button x:Name="SpBindBtn"
                                                            Style="{StaticResource DarkBtn}"
                                                            Margin="0,5,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="SpBindBtn_Click"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="MODE"
                                                               FontFamily="{StaticResource IBMPlexMono}"
                                                               FontSize="9" Foreground="#5a5a5a"/>
                                                    <Button x:Name="SpModeBtn"
                                                            Style="{StaticResource DarkBtn}"
                                                            Margin="0,5,0,0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="SpModeBtn_Click"/>
                                                    <Border x:Name="SpModeDropdown"
                                                            Height="0"
                                                            ClipToBounds="True"
                                                            Background="#080808"
                                                            BorderBrush="#1e1e1e"
                                                            BorderThickness="1"
                                                            Margin="0,2,0,0">
                                                        <StackPanel>
                                                            <Button x:Name="SpModeToggleBtn"
                                                                    Content="Toggle"
                                                                    FontFamily="{StaticResource IBMPlexMono}"
                                                                    FontSize="10"
                                                                    Foreground="#f5f5f5"
                                                                    BorderThickness="0"
                                                                    Padding="10,6,10,6"
                                                                    HorizontalContentAlignment="Left"
                                                                    Cursor="Hand"
                                                                    Click="SpModeToggleBtn_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="Bd" Property="Background" Value="#1a1a1a"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                            <Rectangle Height="1" Fill="#1e1e1e"/>
                                                            <Button x:Name="SpModeHoldBtn"
                                                                    Content="Hold"
                                                                    FontFamily="{StaticResource IBMPlexMono}"
                                                                    FontSize="9"
                                                                    Foreground="#5a5a5a"
                                                                    BorderThickness="0"
                                                                    Padding="10,5,10,5"
                                                                    HorizontalContentAlignment="Left"
                                                                    Cursor="Hand"
                                                                    Click="SpModeHoldBtn_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="Template">
                                                                            <Setter.Value>
                                                                                <ControlTemplate TargetType="Button">
                                                                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                                    </Border>
                                                                                    <ControlTemplate.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter TargetName="Bd" Property="Background" Value="#1a1a1a"/>
                                                                                        </Trigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <Border BorderBrush="#1e1e1e" BorderThickness="0,1,0,0"
                                                    Padding="18,12,18,14">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,8">
                                                        <TextBlock Text="DELAY (MS)"
                                                                   FontFamily="{StaticResource IBMPlexMono}"
                                                                   FontSize="9" Foreground="#5a5a5a"/>
