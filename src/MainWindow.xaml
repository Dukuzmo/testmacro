                                </StackPanel>

                            </Grid>
                        </ScrollViewer>

                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="GoodbyeOverlay"
                    Panel.ZIndex="100"
                    Visibility="Collapsed"
                    Opacity="0"
                    Background="#080808">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="GOODBYE."
                               FontFamily="{StaticResource BebasNeue}"
                               FontSize="72"
                               Foreground="#f5f5f5"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="See you next time."
                               FontFamily="{StaticResource IBMPlexMono}"
                               FontSize="11"
                               Foreground="#5a5a5a"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

        </Grid>
    </Border>

</Window>
